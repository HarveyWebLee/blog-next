# =============================================================================
# Docker Compose / 流水线部署环境变量模板
# -----------------------------------------------------------------------------
# 使用方式：
#   cp deploy/env.docker.example deploy/.env.docker
#   修改下列占位符后执行：
#   docker compose --env-file deploy/.env.docker up -d mysql redis
#   docker compose --env-file deploy/.env.docker --profile migrate run --rm db-migrate
#   docker compose --env-file deploy/.env.docker up -d blog-web
#
# deploy/.env.docker 已在 .gitignore 中，请勿提交真实密钥。
# 与本地开发 env.example 的差异：DB_HOST 在容器内由 compose 覆盖为 mysql，此处可保留模板值。
# =============================================================================

# --- MySQL（mysql 服务 + 与 blog-web / db-migrate 共用的账户，默认 root）---
MYSQL_ROOT_PASSWORD=请改为强密码
MYSQL_DATABASE=blog_system
# 宿主机映射端口（仅开发/排障；生产可改为不暴露，见 Docker 部署文档）
MYSQL_PUBLISH_PORT=13307

# 应用连接用（与 blog-web / db-migrate 中环境变量一致时可省略重复，此处列出便于对照 env.example）
DB_USER=root
# 若使用 root，可与 MYSQL_ROOT_PASSWORD 相同；compose 中 blog-web 默认取 MYSQL_ROOT_PASSWORD
DB_PASSWORD=请改为与 MYSQL_ROOT_PASSWORD 一致或与 DB_USER 匹配
DB_NAME=blog_system

# --- Redis（生产建议启用 requirepass）---
REDIS_PUBLISH_PORT=16380
# Redis requirepass（必填）
REDIS_PASSWORD=请改为强密码
# 应用连接地址（容器内固定使用 redis 服务名）
REDIS_URL=redis://:请改为强密码@redis:6379

# --- Next.js 应用（blog-web）---
NODE_ENV=production
# 浏览器端可见：请改为实际访问协议与域名或宿主机 IP
NEXT_PUBLIC_APP_URL=http://localhost:13001
APP_PORT=13001

# JWT（生产必填，与 env.example 一致）
JWT_SECRET=请改为长随机串
JWT_REFRESH_SECRET=请改为另一长随机串
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 邮件 / 上传等（按需与 env.example 对齐）
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# 其他（可选）
CORS_ORIGIN=http://localhost:13001
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100
CACHE_TTL=3600
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp
