# =============================================================================
# Docker Compose / 流水线部署环境变量模板
# -----------------------------------------------------------------------------
# 使用方式：
#   cp deploy/env.docker.example deploy/.env.docker
#   修改下列占位符后执行：
#   docker compose --env-file deploy/.env.docker up -d mysql redis minio
#   docker compose --env-file deploy/.env.docker --profile minio-init run --rm minio-init
#   docker compose --env-file deploy/.env.docker --profile migrate run --rm db-migrate
#   docker compose --env-file deploy/.env.docker up -d blog-web
#
# deploy/.env.docker 已在 .gitignore 中，请勿提交真实密钥。
#
# 与根目录 env.example 的关系（键不必一一相同）：
# - 本文件：Compose 插值 + 各容器 env（含 MySQL/Redis/MinIO 镜像专用变量）。
# - env.example：仅「宿主机 pnpm dev」下的 Next；不读本文件。MinIO 的 endpoint 在本地多为
#   http://127.0.0.1:19000，在 blog-web 容器内由 compose 写死为 http://minio:9000。
# - 同一套 MinIO 时：MINIO_BUCKET、账号、NEXT_PUBLIC_MINIO_* 应与 .env.local 对齐，避免桶名不一致。
# =============================================================================

# --- MySQL（mysql 服务 + 与 blog-web / db-migrate 共用的账户，默认 root）---
MYSQL_ROOT_PASSWORD=请改为强密码
MYSQL_DATABASE=blog_system
# 宿主机映射端口（仅开发/排障；生产可改为不暴露，见 Docker 部署文档）
MYSQL_PUBLISH_PORT=13307

# 应用连接用（与 blog-web / db-migrate 中环境变量一致时可省略重复，此处列出便于对照 env.example）
DB_USER=root
# 若使用 root，可与 MYSQL_ROOT_PASSWORD 相同；compose 中 blog-web 默认取 MYSQL_ROOT_PASSWORD
DB_PASSWORD=请改为与 MYSQL_ROOT_PASSWORD 一致或与 DB_USER 匹配
DB_NAME=blog_system

# --- MinIO（S3 兼容；文章封面/公开插图 bucket；数据绑定宿主机目录）---
# 控制台：https://docs.min.io/docs/minio-docker-quickstart-guide.html
# MINIO_ROOT_USER：至少 3 字符；MINIO_ROOT_PASSWORD：至少 8 字符（MinIO 强制策略）
MINIO_ROOT_USER=请改为minio访问密钥
MINIO_ROOT_PASSWORD=请改为至少8位强密码
# 宿主机上存放对象的目录，绑定到容器内 /data。不写本变量或留空时，Compose 使用默认值 ./data/minio。
# 相对路径（如 ./data/minio）相对于 docker-compose.yml 所在目录（仓库根），不随你执行命令时 cd 到哪而改变。
# 生产 Linux 可改为绝对路径，例如 /var/lib/blog-next/minio-data。
# macOS Docker Desktop：勿用 /data/minio 等根下路径（默认未加入 File Sharing，会报 mounts denied）；请用 ./data/minio 或 /Users/你/... 下的目录。
MINIO_HOST_DATA_DIR=./data/minio
# 供 mc 初始化与后续应用写入的默认 bucket（匿名可读下载，仅适合公开配图）
MINIO_BUCKET=blog-public
MINIO_API_PUBLISH_PORT=19000
MINIO_CONSOLE_PUBLISH_PORT=19001
# Next.js（blog-web）连接 MinIO S3 API：容器内必须用服务名
MINIO_ENDPOINT=http://minio:9000
# 可与 MINIO_ROOT_* 相同；若不用独立账号请两行均留空，勿填中文占位句（否则会优先于 ROOT 导致 InvalidAccessKeyId）
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
# 浏览器访问对象的基址（无尾斜杠）。模板用 127.0.0.1:19000 仅适合本机/内网调试。
# 生产请勿用 127.0.0.1：应改为读者浏览器能访问的地址，如 https://img.example.com 或 https://服务器公网IP:端口（更推荐反代+HTTPS+独立域名）。
MINIO_PUBLIC_BASE_URL=http://127.0.0.1:19000
# 构建期/客户端：须与 MINIO_BUCKET、MINIO_PUBLIC_BASE_URL 语义一致（同一套对外基址）。
# 生产与上一行改为同一公网/域名；改后需重新 docker compose build blog-web（NEXT_PUBLIC 在 build 时内联）。
NEXT_PUBLIC_MINIO_BUCKET=blog-public
NEXT_PUBLIC_MINIO_PUBLIC_BASE_URL=http://127.0.0.1:19000

# --- Redis（生产建议启用 requirepass）---
REDIS_PUBLISH_PORT=16380
# Redis requirepass（必填）
REDIS_PASSWORD=请改为强密码
# 应用连接地址（容器内固定使用 redis 服务名）
REDIS_URL=redis://:请改为强密码@redis:6379

# --- Next.js 应用（blog-web）---
NODE_ENV=production
# 浏览器端可见：请改为实际访问协议与域名或宿主机 IP
NEXT_PUBLIC_APP_URL=http://localhost:13001
APP_PORT=13001

# JWT（生产必填，与 env.example 一致）
JWT_SECRET=请改为长随机串
JWT_REFRESH_SECRET=请改为另一长随机串
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# --- 密码应用层传输加固（生产强烈建议开启）---
# 先执行：node scripts/generate-password-transport-keys.mjs
# 将输出的一行写入 PASSWORD_TRANSPORT_RSA_PRIVATE_KEY_B64（勿提交真实值）
PASSWORD_TRANSPORT_RSA_PRIVATE_KEY_B64=
# 是否强制密码字段必须使用 passwordTransport：
# - 建议生产保持 true（未配私钥时密码接口会返回 503）
PASSWORD_TRANSPORT_REQUIRED=true
# 允许客户端时间戳偏差（毫秒）
PASSWORD_TRANSPORT_MAX_SKEW_MS=300000
# 文章解锁票据有效期（秒），用于 query.unlock（不再在 URL 传明文密码）
POST_PASSWORD_UNLOCK_EXPIRES_SECONDS=600
# 可选：解锁票据专用密钥（未配置时回退 JWT_SECRET；生产建议单独配置）
POST_PASSWORD_UNLOCK_SECRET=请改为长随机串

# --- 内存态超级管理员（blog-web 容器；lib/config/super-admin.ts；默认关闭）---
# 应急登录（数据库不可用）、无用户 bootstrap、运维兜底。安全风险高，生产慎用。
# 推荐交互生成 Base64：pnpm super-admin:hash（容器内/CI 可用 echo pass | pnpm super-admin:hash --stdin）
# SUPER_ADMIN_ENABLED=false
# SUPER_ADMIN_USERNAME=root
# SUPER_ADMIN_PASSWORD_BCRYPT_BASE64=
# 或与 BASE64 二选一：SUPER_ADMIN_PASSWORD_BCRYPT="..."

# 邮件 / 上传等（按需与 env.example 对齐）
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# 其他（可选）
CORS_ORIGIN=http://localhost:13001
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100
CACHE_TTL=3600
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp
