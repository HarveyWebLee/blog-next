{
  "name": "blog-next",
  "version": "1.4.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HarveyWebLee/blog-next.git"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint \"./**/*.+(ts|tsx)\"",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:migrate:run": "tsx scripts/run-drizzle-migrate.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts --port=4984",
    "db:seed": "npx tsx scripts/seed.ts",
    "db:reset:dev": "npx tsx scripts/reset-database-dev.ts",
    "db:reset:prod": "npx tsx scripts/reset-database-prod.ts",
    "db:backup": "npx tsx scripts/backup-database.ts",
    "db:verify": "npx tsx scripts/verify-system.ts",
    "db:clear": "npx tsx scripts/clear-data.ts",
    "test:api": "npx tsx scripts/test-api.ts",
    "test:db:env": "npx tsx scripts/setup-env.ts",
    "test:db:connect": "npx tsx scripts/test-db-connect.ts",
    "test:email": "npx tsx scripts/test-email.ts",
    "format": "prettier . --write",
    "lint:fix": "eslint \"./**/*.+(ts|tsx)\" --fix",
    "format:check": "prettier . --check",
    "browserslist:update": "pnpm up caniuse-lite baseline-browser-mapping --depth Infinity",
    "prepare": "husky",
    "precommit": "pnpm format:check && pnpm typecheck && lint-staged",
    "release:dry-run": "semantic-release --dry-run",
    "docker:up:deps": "docker compose --env-file deploy/.env.docker up -d mysql redis minio",
    "docker:minio:init": "docker compose --env-file deploy/.env.docker --profile minio-init run --rm minio-init",
    "docker:migrate": "docker compose --env-file deploy/.env.docker --profile migrate run --rm --build db-migrate",
    "docker:up:app": "docker compose --env-file deploy/.env.docker up -d --build blog-web",
    "docker:down": "docker compose --env-file deploy/.env.docker down",
    "super-admin:hash": "node scripts/super-admin-hash.mjs"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss,mjs,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@formatjs/intl-localematcher": "^0.6.1",
    "@heroui/button": "2.2.25",
    "@heroui/input": "2.4.26",
    "@heroui/link": "2.2.22",
    "@heroui/popover": "2.3.25",
    "@heroui/react": "^2.8.3",
    "@heroui/spinner": "^2.2.23",
    "@heroui/switch": "2.2.23",
    "@heroui/system": "2.4.21",
    "@heroui/theme": "2.4.21",
    "@heroui/toast": "^2.0.16",
    "@react-aria/ssr": "3.9.10",
    "@toast-ui/editor": "^3.2.2",
    "@toast-ui/react-editor": "^3.2.3",
    "@types/nodemailer": "^7.0.2",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "2.1.1",
    "dayjs": "^1.11.18",
    "drizzle-orm": "^0.44.5",
    "framer-motion": "12.23.12",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.544.0",
    "mysql2": "^3.14.4",
    "negotiator": "^1.0.0",
    "next": "15.1.3",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.9",
    "nprogress": "^0.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "2.5.4",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.15.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^22.10.2",
    "@types/nprogress": "^0.2.3",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/three": "^0.183.1",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.1.3",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^15.11.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2",
    "prettier-plugin-css-order": "^2.1.2",
    "prettier-plugin-sort-json": "^4.1.1",
    "sass": "^1.93.2",
    "semantic-release": "^25.0.3",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.20.5",
    "typescript": "^5.7.2"
  }
}
