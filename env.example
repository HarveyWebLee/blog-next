# =============================================================================
# 本地开发（pnpm dev）：复制为 .env.local 后填写
# -----------------------------------------------------------------------------
# 本文件只服务「宿主机上跑的 Next.js 进程」。Next 默认不会读取 deploy/.env.docker。
#
# 为何与 deploy/env.docker.example 不一致（属正常设计，不是遗漏）：
# - deploy 模板多了：MYSQL_*、端口映射、REDIS_*、MINIO_HOST_DATA_DIR、APP_PORT、
#   CORS_* 等 —— 给 docker compose 插值与 mysql/redis/minio 容器用，本地 Next 不读。
# - 本地独有：DB_HOST=localhost、MINIO_ENDPOINT=127.0.0.1:19000（容器内则是 http://minio:9000）。
# - 两边若都用 MinIO：MINIO_BUCKET / 账号 应对齐同一套 MinIO；路径与端口按环境各写各的。
# 统一部署说明：docs/Docker编排与流水线部署.md
# =============================================================================

# --- 数据库（lib/db/config.ts、drizzle.config.ts、脚本）---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=blog_system

# 如果你的 Redis 开了 requirepass（docker-compose 里默认会开）
# REDIS_URL=redis://:你的_redis密码@127.0.0.1:16380
REDIS_URL=redis://:你的_redis密码@redis:6379
# 如果没开密码，就用：redis://127.0.0.1:16380

# --- 应用 ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- JWT（lib/utils/auth.ts）---
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# --- 内存态超级管理员（lib/config/super-admin.ts；应急登录 / bootstrap；默认关闭）---
# 开启后登录接口会优先校验本账号，不访问 users 表；JWT 中 userId=0、role=super_admin、isRoot=true。
# 生产务必：强密码、限制网络访问、勿提交真实 env。
# 推荐：交互式生成 bcrypt→Base64 一行（避免 $ 在 .env 中被截断）：pnpm super-admin:hash
# 若已有 60 字符明文哈希，仅转 Base64：pnpm exec node scripts/encode-bcrypt-b64.mjs '$2b$12$...'
# SUPER_ADMIN_ENABLED=false
# SUPER_ADMIN_USERNAME=root
# SUPER_ADMIN_PASSWORD_BCRYPT_BASE64=粘贴 encode-bcrypt-b64.mjs 输出的整行
# 或与 BASE64 二选一（明文含 $，在部分环境下易被截断）：SUPER_ADMIN_PASSWORD_BCRYPT="..."

# --- 对象存储 MinIO（特色图上传；lib/services/object-storage.service.ts）---
# 以下全部有效（endpoint + 凭证 + bucket + 公开基址 + NEXT_PUBLIC_*）时启用上传；否则仍可手动填图片 URL。
MINIO_ENDPOINT=http://127.0.0.1:19000
MINIO_REGION=us-east-1
MINIO_BUCKET=blog-public
MINIO_PUBLIC_BASE_URL=http://127.0.0.1:19000
# 访问密钥：须「同时留空」或「同时填写」；只填一项会忽略并改用 MINIO_ROOT_*（避免占位符误当 Access Key）
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
# 须与 MINIO_BUCKET、MINIO_PUBLIC_BASE_URL 一致（客户端解析已上传 URL、换图删旧）
NEXT_PUBLIC_MINIO_BUCKET=blog-public
NEXT_PUBLIC_MINIO_PUBLIC_BASE_URL=http://127.0.0.1:19000

# --- 邮件（lib/utils/email.ts）---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# --- 可选（脚本用，应用核心不依赖）---
# TEST_EMAIL=test@example.com
