# 本地开发：复制为 .env.local 后按需填写。
# Compose / 服务器部署（MySQL、Redis、MinIO、REDIS_URL 等）见 deploy/env.docker.example 与 docs/Docker编排与流水线部署.md

# 数据库（lib/db/config.ts、drizzle.config.ts、脚本）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=blog_system

# 应用
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# JWT（lib/utils/auth.ts）
JWT_SECRET=your_jwt_secret_key_here
# 刷新令牌签名密钥（不设则回退到内置默认值，生产环境请必填）
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 对象存储 MinIO（特色图上传等；未配置时仅可手动填图片 URL）
# 服务端：S3 API 地址（本机 Docker 映射一般为 http://127.0.0.1:19000；容器内为 http://minio:9000）
# MINIO_ENDPOINT=http://127.0.0.1:19000
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_BUCKET=blog-resource
# MINIO_REGION=us-east-1
# 浏览器可访问的基址（无尾斜杠，用于拼接公开 URL）
# MINIO_PUBLIC_BASE_URL=http://127.0.0.1:19000
# 客户端解析已上传 URL 用（须与 MINIO_BUCKET、公开访问路径一致）
# NEXT_PUBLIC_MINIO_BUCKET=blog-resource
# NEXT_PUBLIC_MINIO_PUBLIC_BASE_URL=http://127.0.0.1:19000

# 邮件（lib/utils/email.ts；注册、重置密码等）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
