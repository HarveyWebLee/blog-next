# 本地开发：复制为 .env.local 后按需填写。
# Compose / 服务器部署（MySQL、Redis、MinIO、REDIS_URL 等）见 deploy/env.docker.example 与 docs/Docker编排与流水线部署.md

# 数据库（lib/db/config.ts、drizzle.config.ts、脚本）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=blog_system

# 应用
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# JWT（lib/utils/auth.ts）
JWT_SECRET=your_jwt_secret_key_here
# 刷新令牌签名密钥（不设则回退到内置默认值，生产环境请必填）
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 邮件（lib/utils/email.ts；注册、重置密码等）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
