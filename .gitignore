# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

bun.lockb

# Drizzle ORM：迁移目录需纳入版本，供 `pnpm db:migrate` / Docker `db-migrate` 使用
# 其他路径下 *.sql 仍忽略（如临时导出）；若你有需提交的根目录 SQL，请改为更精确规则
*.sql
!drizzle/**/*.sql

.backups
.env.local

# Docker Compose 本地密钥（从 deploy/env.docker.example 复制）
deploy/.env.docker

# blog-edge：生产真实 Secret（单行文件目录；模板见 deploy/secrets/edge.example/）
deploy/secrets/edge/

# 若将 MinIO 数据绑定到仓库下目录（如 ./data/minio:/data），勿提交对象文件
/data/minio/

# CI/部署过程中临时目录（如 deploy workflow 设置 TMPDIR=.tmp）
/.tmp/

# API 文档构建产物（由 pnpm api-docs:generate / prebuild 自动生成）
/generated/api-docs-manifest.json