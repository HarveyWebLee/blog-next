{
  "attribution": {
    "attributeCommitsToAgent": false,
    "attributePRsToAgent": false
  },
  "editor": {
    "vimMode": false
  },
  "network": {
    "useHttp1ForAgent": false
  },
  "permissions": {
    "allow": [
      "ReadFile",
      "Glob",
      "rg",
      "ReadLints",
      "ApplyPatch",
      "EditNotebook",
      "Delete",
      "Shell(pwd)",
      "Shell(ls)",
      "Shell(rg *)",
      "Shell(git status*)",
      "Shell(git diff*)",
      "Shell(git log*)",
      "Shell(git add*)",
      "Shell(git commit*)",
      "Shell(pnpm install*)",
      "Shell(pnpm dev*)",
      "Shell(pnpm lint*)",
      "Shell(pnpm typecheck*)",
      "Shell(pnpm format:check*)",
      "Shell(pnpm precommit*)",
      "Shell(pnpm db:generate*)",
      "Shell(pnpm db:migrate*)",
      "Shell(pnpm db:push*)",
      "Shell(npx tsx scripts/*)"
    ],
    "deny": [
      "Shell(rm *)",
      "Shell(del *)",
      "Shell(git reset --hard*)",
      "Shell(git checkout --*)",
      "Shell(git clean -fd*)",
      "Shell(git push --force*)",
      "Shell(sudo *)",
      "Shell(chmod 777*)"
    ]
  },
  "version": 1
}
